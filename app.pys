# ============================================================
#  HACK4GOV - CCS WEEK 2025 | Basilan State College
#  Flask Backend - app.py
#  Database: SQLite (works perfectly on PythonAnywhere!)
#
#  WHY SQLITE INSTEAD OF MYSQL?
#    - No installation needed — Python includes it built-in!
#    - PythonAnywhere supports it without any extra configuration
#    - The database is just a single file: hack4gov.db
#    - Perfect for small-to-medium projects like this one
#
#  WHAT YOU ALREADY KNOW:
#    - url_for()         → builds a URL to a route/function
#    - render_template() → loads an HTML file from /templates/
#    - redirect()        → sends the user to another page
#    - request           → reads data sent by the browser/form
# ============================================================


# --- IMPORTS ------------------------------------------------
from flask import Flask, request, jsonify, redirect, url_for, render_template

import sqlite3
# sqlite3 → Python's built-in database library, NO pip install needed!
# Think of it like Excel but you control it with code.

import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
# These three handle building and sending emails

import secrets
# secrets → generates a random token for each registrant's confirmation link

import os
# os → used to safely build the file path for the database
# ------------------------------------------------------------


app = Flask(__name__)


# ============================================================
#  DATABASE CONFIGURATION
#  SQLite stores EVERYTHING in one file: hack4gov.db
#  It will be created automatically the first time you run
#  the app — no MySQL Workbench, no setup commands needed!
# ============================================================

DB_PATH = os.path.join(os.path.dirname(__file__), 'hack4gov.db')
# __file__         → the location of this app.py file
# os.path.dirname  → gets the folder that contains app.py
# os.path.join     → combines folder + filename safely
# Result example:  /home/yourname/myproject/hack4gov.db


def get_db():
    """
    Opens a connection to the SQLite database.
    Think of this like 'opening' the Excel file before reading/writing.
    We call this at the start of every route that needs the database.
    """
    conn = sqlite3.connect(DB_PATH)

    # row_factory lets us access columns by name instead of by index
    # Without it: row[0] → With it: row['name']  ← much easier!
    conn.row_factory = sqlite3.Row

    return conn


def init_db():
    """
    Creates the registrations table if it doesn't exist yet.
    Runs once when the app starts. Safe to run every time.
    IF NOT EXISTS means it won't crash if the table already exists.
    """
    conn = get_db()
    conn.execute("""
        CREATE TABLE IF NOT EXISTS registrations (
            id             INTEGER PRIMARY KEY AUTOINCREMENT,
            name           TEXT    NOT NULL,
            age            INTEGER NOT NULL,
            course_year    TEXT    NOT NULL,
            contact_number TEXT    NOT NULL,
            email          TEXT    NOT NULL UNIQUE,
            confirmed      INTEGER DEFAULT 0,
            token          TEXT    NOT NULL,
            registered_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    """)
    # AUTOINCREMENT → SQLite auto-assigns 1, 2, 3... as IDs for each row
    # UNIQUE        → no two people can register with the same email
    # confirmed = 0 → SQLite uses 0 for FALSE and 1 for TRUE
    # CURRENT_TIMESTAMP → automatically saves the date/time of registration

    conn.commit()   # save the changes to disk
    conn.close()    # close the connection (good habit — like closing a file)


# ============================================================
#  EMAIL CONFIGURATION
#  We use Gmail's SMTP server to send confirmation emails.
#  SMTP = the protocol (set of rules) used to send email.
# ============================================================

EMAIL_SENDER   = 'kleia6678@gmail.com'     # TODO: your Gmail address
EMAIL_PASSWORD = 'smwqemlpykznlvxh'        # TODO: Gmail App Password (NOT your real Gmail password!)
                                           #
                                           # HOW TO GET AN APP PASSWORD:
                                           # 1. Go to myaccount.google.com
                                           # 2. Security → 2-Step Verification (enable it)
                                           # 3. Security → App Passwords
                                           # 4. Create one for "Mail" → paste it here

# On PythonAnywhere your URL looks like: https://yourusername.pythonanywhere.com
BASE_URL = 'http://localhost:5000'         # TODO: change this when you deploy to PythonAnywhere


def send_confirmation_email(to_email, name, token):
    """
    Builds and sends a confirmation email to the registrant.

    Parameters:
        to_email (str) → the registrant's email address
        name     (str) → used to personalize the email ("Hi Juan!")
        token    (str) → the unique code that goes in the confirmation link
    """
    confirm_url = f"{BASE_URL}/confirm/{token}"
    # f-string → puts the variable value directly into the string
    # Result example: http://localhost:5000/confirm/aB3xZ9qR2mK...

    # Build the email message
    msg = MIMEMultipart('alternative')   # 'alternative' means we send both plain text and HTML
    msg['Subject'] = '[ HACK4GOV ] Confirm Your Registration'
    msg['From']    = EMAIL_SENDER
    msg['To']      = to_email

    # Plain text version (fallback for email clients that don't support HTML)
    text_body = f"""
Hi {name},

You have successfully registered for HACK4GOV - CCS Week 2025!

Please confirm your email by visiting this link:
{confirm_url}

See you on April 21-23!
— CCS, Basilan State College
    """

    # HTML version (the nice-looking email)
    html_body = f"""
    <div style="font-family: monospace; background: #0a0a0a; color: #f0f0f0; padding: 32px; max-width: 500px;">
        <div style="background: #8B1A1A; padding: 10px 20px; margin-bottom: 20px;">
            <span style="letter-spacing: 4px; font-size: 18px; font-weight: bold;">HACK4GOV</span>
            <span style="float:right; font-size: 11px; color: #ffd0d0;">CCS WEEK 2025</span>
        </div>
        <p style="color: #aaa; font-size: 13px;">REGISTRATION RECEIVED</p>
        <p style="font-size: 16px;">Hi <strong style="color:#c0392b">{name}</strong>,</p>
        <p style="color: #ccc; line-height: 1.7;">
            You're almost in! Click the button below to confirm your
            email and lock in your slot for the competition.
        </p>
        <a href="{confirm_url}"
           style="display:inline-block; margin: 20px 0; padding: 12px 28px;
                  background: #8B1A1A; color: #fff; text-decoration: none;
                  letter-spacing: 2px; font-size: 14px; font-weight: bold;">
            [ CONFIRM MY REGISTRATION ]
        </a>
        <p style="color: #555; font-size: 11px;">
            If the button doesn't work, copy this link:<br>
            <a href="{confirm_url}" style="color: #8B1A1A;">{confirm_url}</a>
        </p>
        <hr style="border-color: #2a0a0a; margin: 20px 0;">
        <p style="color: #444; font-size: 11px; letter-spacing: 1px;">
            COLLEGE OF COMPUTING STUDIES — BASILAN STATE COLLEGE<br>
            APR 21-23, 2025
        </p>
    </div>
    """

    msg.attach(MIMEText(text_body, 'plain'))
    msg.attach(MIMEText(html_body, 'html'))

    # Connect to Gmail and send
    try:
        with smtplib.SMTP('smtp.gmail.com', 587) as server:
            # port 587 = Gmail's secure sending port
            server.starttls()                               # encrypt the connection
            server.login(EMAIL_SENDER, EMAIL_PASSWORD)      # log in to Gmail
            server.sendmail(EMAIL_SENDER, to_email, msg.as_string())
        return True    # email sent successfully!

    except Exception as e:
        print(f"Email error: {e}")   # check your terminal/PythonAnywhere logs
        return False


# ============================================================
