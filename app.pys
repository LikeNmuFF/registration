# ============================================================
#  API ROUTE 1: Register
#  POST /api/register
#
#  This is called automatically by the JavaScript fetch() in
#  your HTML form when someone clicks "REGISTER NOW".
#
#  HOW JSON WORKS HERE:
#    1. The form sends data as JSON:  { "name": "Juan", "email": "..." }
#    2. request.get_json() reads it into a Python dictionary
#    3. We process it, save to DB, send email
#    4. jsonify() sends a response back:  { "success": true }
#    5. The JavaScript reads that and shows a success/error message
# ============================================================

@app.route('/api/register', methods=['POST'])
def register():

    # Step 1: Read the JSON body sent by the form
    data = request.get_json()
    # data is now a Python dict like: { "name": "Juan", "age": "20", ... }

    # Step 2: Pull out each field
    # .get('key', '') → safely gets the value, or '' if missing
    # .strip()        → removes extra spaces the user might have typed
    name           = data.get('name', '').strip()
    age            = data.get('age', '').strip()
    course_year    = data.get('course_year', '').strip()
    contact_number = data.get('contact_number', '').strip()
    email          = data.get('email', '').strip()

    # Step 3: Make sure nothing is empty
    if not all([name, age, course_year, contact_number, email]):
        # jsonify turns a Python dict into a JSON response for the frontend
        return jsonify({ 'success': False, 'message': 'All fields are required.' })

    # TODO: add more validation here if you want to explore further!
    # Ideas: check age is a number, email has @ sign, contact is 11 digits, etc.

    # Step 4: Generate a unique token for this person's confirmation link
    token = secrets.token_urlsafe(32)
    # Generates a random string like: "aB3xZ9qR2mK7wP1nY6hT0cD5vL8eJ4uF"
    # Only this person will have this exact token in their email

    # Step 5: Save to the SQLite database
    try:
        conn = get_db()
        conn.execute("""
            INSERT INTO registrations (name, age, course_year, contact_number, email, token)
            VALUES (?, ?, ?, ?, ?, ?)
        """, (name, age, course_year, contact_number, email, token))
        # In SQLite, ? are the placeholders (MySQL uses %s — small but important difference!)
        # The tuple fills them in order: name→1st ?, age→2nd ?, and so on

        conn.commit()   # save to disk
        conn.close()

    except sqlite3.IntegrityError:
        # This error fires when the UNIQUE constraint is violated
        # meaning someone already used this email to register
        return jsonify({ 'success': False, 'message': 'This email is already registered.' })

    except Exception as e:
        print(f"Database error: {e}")
        return jsonify({ 'success': False, 'message': 'Database error. Please try again.' })

    # Step 6: Send the confirmation email
    email_sent = send_confirmation_email(email, name, token)

    if not email_sent:
        # Registration is saved but email failed — still let them know they're registered
        return jsonify({
            'success': True,
            'message': 'Registered! But we could not send the confirmation email. Please contact the organizers.'
        })

    # Step 7: All good! Tell the frontend it worked.
    return jsonify({ 'success': True })


# ============================================================
#  API ROUTE 2: Get Confirmed Participants
#  GET /api/participants
#
#  Called by the JavaScript in your participants.html page
#  to load and display the list of confirmed players.
# ============================================================

@app.route('/api/participants')
def get_participants():

    try:
        conn = get_db()

        # Read only confirmed registrants (confirmed = 1 means TRUE in SQLite)
        # ORDER BY registered_at ASC → first to register appears first
        rows = conn.execute("""
            SELECT name, course_year
            FROM registrations
            WHERE confirmed = 1
            ORDER BY registered_at ASC
        """).fetchall()
        # .fetchall() → returns ALL matching rows as a list

        conn.close()

    except Exception as e:
        print(f"Database error: {e}")
        return jsonify({ 'participants': [] })

    # Convert each row into a plain dictionary so jsonify can handle it
    # Because we set row_factory = sqlite3.Row, dict(row) works directly
    participants = [dict(row) for row in rows]
    # Result: [{"name": "Juan", "course_year": "BSCS 3"}, ...]

    return jsonify({ 'participants': participants })


# ============================================================
#  ROUTE 3: Email Confirmation
#  GET /confirm/<token>
#
#  The user clicks the link in their email → browser opens this URL
#  → we check the token → mark them confirmed → redirect them
#
#  <token> is a URL variable. Flask automatically passes whatever
#  is in the URL as the `token` parameter to this function.
#  Example URL: /confirm/aB3xZ9qR2mK7wP1nY6hT0cD5vL8eJ4uF
# ============================================================

@app.route('/confirm/<token>')
def confirm_email(token):

    try:
        conn = get_db()

        # Look for a registration with this token that isn't confirmed yet
        row = conn.execute("""
            SELECT id FROM registrations
            WHERE token = ? AND confirmed = 0
        """, (token,)).fetchone()
        # (token,) → the comma makes it a tuple, which SQLite requires for parameters

        if row is None:
            conn.close()
            # TODO: make a nicer error page → create templates/invalid.html
            return "This confirmation link is invalid or has already been used.", 400

        # Token is valid! Mark this person as confirmed.
        conn.execute("""
            UPDATE registrations
            SET confirmed = 1
            WHERE token = ?
        """, (token,))

        conn.commit()
        conn.close()

    except Exception as e:
        print(f"Database error: {e}")
        return "Something went wrong. Please contact the organizers.", 500

    # Redirect to the participants page so they can see their name listed
    # redirect() and url_for() — you already know these!
    return redirect(url_for('participants_page'))


# ============================================================
#  INITIALIZE DATABASE + RUN APP
# ============================================================

# init_db() runs once when Flask starts.
# It creates hack4gov.db and the table if they don't exist yet.
with app.app_context():
    init_db()

if __name__ == '__main__':
    app.run(debug=True)
    # TODO: change debug=True to debug=False before uploading to PythonAnywhere!
    #       debug=True shows error details in the browser — fine locally, risky online.
